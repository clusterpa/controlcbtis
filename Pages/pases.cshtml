@page
@model controlcbtis.Pages.pasesModel
@{
}

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f5f7fb;
    }

    .card {
        background: white;
        padding: 20px;
        margin: 20px auto;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05);
        max-width: 1100px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 2fr auto;
        gap: 15px;
        align-items: end;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    input {
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    input:focus {
        outline: none;
        border-color: #4f46e5;
    }

    .btn {
        background: #4f46e5;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        cursor: pointer;
        transition: .3s;
    }

    .btn:hover {
        background: #4338ca;
    }

    .btnEliminar {
        background: #dc2626;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 8px;
        cursor: pointer;
    }

    .btnEliminar:hover {
        background: #b91c1c;
    }

    .btnPase {
        background: #16a34a;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 8px;
        cursor: pointer;
    }

    .btnPase:hover {
        background: #15803d;
    }

    .tabla {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    .tabla th {
        background: #4f46e5;
        color: white;
        padding: 12px;
    }

    .tabla td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
        text-align: center;
    }

    .tabla tr:hover {
        background: #f3f4ff;
    }

    

    .modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
    }

    .modal-content {
        width: 650px;
        background: white;
        margin: 40px auto;
        border-radius: 15px;
        padding: 25px;
    }

    .modal-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 15px;
    }

    textarea {
        width: 100%;
        border-radius: 8px;
        border: 1px solid #ccc;
        padding: 10px;
        resize: none;
    }

    .acciones{
        margin-top:20px;
        display:flex;
        justify-content:end;
        gap:10px;
    }

</style>


<div class="card">

    <h2>Pases de salida para docentes</h2>

    <form method="post" class="form-grid">

        <div class="form-group">

            <label>Nombre del docente</label>

            <input asp-for="NuevoDocente.Nombre"
                   type="text"
                   placeholder="Escriba el nombre del docente..." />

        </div>

        <button type="submit" class="btn">

            Agregar Docente

        </button>

    </form>

</div>



<div class="card">

    <h3>Docentes registrados</h3>

    <table class="tabla">

        <thead>

            <tr>

                <th>Nombre</th>

                <th width="300">Acciones</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var docente in Model.ListaDocentes)
            {
                <tr>

                    <td>@docente.Nombre</td>

                    <td>

                        <button class="btnPase"
                                type="button"
                                onclick="abrirModal('@docente.Nombre')">

                            Generar Pase

                        </button>

                        <form method="post"
                              asp-page-handler="Eliminar"
                              style="display:inline;">

                            <input type="hidden"
                                   name="id"
                                   value="@docente.Id" />

                            <button type="submit"
                                    class="btnEliminar">

                                Eliminar

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>




<div class="modal" id="modalPase">

    <form method="post" asp-page-handler="GenerarPase">

    <div class="modal-content">

        <h2>Generar Pase de Salida</h2>

        <br>

        <div class="modal-grid">

            <div class="form-group">

                <label>Docente</label>

                <input id="nombreDocente"
                       asp-for="NuevoPase.NombreDocente"
                       readonly />

            </div>

            <div class="form-group">

                <label>Fecha</label>

                <input asp-for="NuevoPase.Fecha"
                       type="date" />

            </div>

            <div class="form-group">

                <label>Hora de salida</label>

                <input asp-for="NuevoPase.HoraSalida"
                       type="time" />

            </div>

            <div class="form-group">

                <label>Hora de regreso</label>

                <input asp-for="NuevoPase.HoraRegreso"
                       type="time" />

            </div>

        </div>

        <br>

        <div class="form-group">

            <label>Motivo</label>

            <textarea asp-for="NuevoPase.Motivo"
                      rows="4"></textarea>

        </div>

        <br>

        <div class="form-group">

            <label>Observaciones</label>

            <textarea asp-for="NuevoPase.Observaciones"
                      rows="3"></textarea>

        </div>

        <div class="acciones">

            <button class="btnEliminar"
                    type="button"
                    onclick="cerrarModal()">

                Cancelar

            </button>

                <button class="btn"
                        type="submit">

                    Generar PDF

                </button>

        </div>

    </div>

            </form>

</div>



<script>

    function abrirModal(nombre){

        document.getElementById("modalPase").style.display="block";

        document.getElementById("nombreDocente").value = nombre;

    }

    function cerrarModal(){

        document.getElementById("modalPase").style.display="none";

    }

</script>
